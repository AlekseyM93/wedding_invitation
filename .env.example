# Публичный URL сайта (без слэша в конце). Обязательно на проде для Open Graph и canonical.
# Пример: https://wedding.example.ru
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Таблица — URL веб-приложения Apps Script (/exec)
GOOGLE_SHEETS_WEBHOOK_URL=

# Секретный токен (тот же, что WEBHOOK_SECRET в Apps Script)
GOOGLE_SHEETS_SECRET=
